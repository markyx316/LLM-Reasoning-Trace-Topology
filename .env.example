# =============================================================================
# Environment Variables for Reasoning Trace UQ Project
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Load before running:
#   source .env
#   # or: export $(grep -v '^#' .env | xargs)

# --- DeepSeek API ---
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: override API base URL (for proxies or compatible APIs)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- HPC Configuration ---
# Conda environment name on your HPC cluster
# CONDA_ENV=trace-uq

# SLURM account/allocation (if required by your cluster)
# SLURM_ACCOUNT=your-account

# --- HuggingFace ---
# Optional: set if you need to authenticate for gated models
# HF_TOKEN=hf_your-token-here

# Cache directory for downloaded models and datasets
# HF_HOME=/scratch/$USER/.cache/huggingface
